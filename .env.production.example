# GreenConnectX - Production Environment Variables
# Copy this file to .env.production and update with your production values

# Database Configuration (Update with your production database)
DB_HOST=your-production-db-host.com
DB_PORT=5432
DB_USER=your_production_user
DB_PASSWORD=your_secure_production_password
DB_NAME=greenconnectx_prod

# Web Server Configuration
PORT=3000
NODE_ENV=production

# Gmail Configuration for Contact Form Emails
GMAIL_USER=greenconnectx.team@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# Optional: Additional security configurations
# SESSION_SECRET=your-super-secure-session-secret
# RATE_LIMIT_MAX=100